# .env.example
# The secure Gemini API key for running server-side AI Compliance Audits
GEMINI_API_KEY=

# Optional SMTP Configuration to send real emails to your personnel's real inbox (Default fallback is Ethereal test inbox)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER=
